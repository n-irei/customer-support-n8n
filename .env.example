# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Slack Incoming Webhook
SLACK_WEBHOOK_URL=your-slack-webhook-url-here

# n8n 設定
N8N_BASIC_AUTH_ACTIVE=true
